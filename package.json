{
  "name": "onward",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @onward/api build",
    "build:mobile": "pnpm --filter @onward/mobile exec expo export --platform web",
    "build:web": "pnpm --filter @onward/web build",
    "check:ai-context": "node ./scripts/sync-ai-context.mjs --check",
    "db:generate": "pnpm --filter @onward/api prisma:generate",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:push": "pnpm --filter @onward/api db:push",
    "db:up": "docker compose up -d db",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @onward/api dev",
    "dev:mobile": "pnpm --filter @onward/mobile dev",
    "dev:mobile:android": "pnpm --filter @onward/mobile android",
    "dev:mobile:ios": "pnpm --filter @onward/mobile ios",
    "dev:mobile:web": "pnpm --filter @onward/mobile web",
    "dev:web": "pnpm --filter @onward/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint:api": "pnpm --filter @onward/api lint",
    "lint:mobile": "pnpm --filter @onward/mobile lint",
    "lint:web": "pnpm --filter @onward/web lint",
    "preview:web": "pnpm --filter @onward/web preview",
    "sync:ai-context": "node ./scripts/sync-ai-context.mjs",
    "start:api": "pnpm --filter @onward/api start",
    "typecheck": "turbo run typecheck",
    "typecheck:api": "pnpm --filter @onward/api typecheck",
    "typecheck:mobile": "pnpm --filter @onward/mobile typecheck",
    "typecheck:web": "pnpm --filter @onward/web typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "latest",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  }
}
