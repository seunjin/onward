generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GoalType {
  todo
  habit
  challenge
}

enum GoalStatus {
  active
  archived
  completed
}

enum CadenceType {
  daily
  weekly
  custom
}

enum RecordStatus {
  done
  skipped
  missed
}

enum AuthProvider {
  google
  apple
}

model User {
  id             String         @id @default(cuid())
  email          String?        @unique
  passwordHash   String?
  nickname       String?
  timezone       String         @default("UTC")
  authIdentities AuthIdentity[]
  goals          Goal[]
  records        Record[]
  refreshTokens  RefreshToken[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        AuthProvider
  providerUserId  String
  email           String?
  emailVerified   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Goal {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  records      Record[]
  title        String
  description  String?
  type         GoalType
  status       GoalStatus  @default(active)
  cadenceType  CadenceType @default(daily)
  cadenceValue Json?
  startDate    DateTime?
  endDate      DateTime?
  targetCount  Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, status])
}

model Record {
  id          String       @id @default(cuid())
  goalId      String
  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      RecordStatus
  performedOn DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([goalId, performedOn])
  @@index([userId, performedOn])
}
